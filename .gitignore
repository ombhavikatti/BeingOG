# ==============================================================================
# BeingOG — .gitignore
# Covers: Node.js, Next.js, NestJS, Python, VS Code, Windows, macOS, Secrets
# ==============================================================================

# ----- Dependencies -----
node_modules/
.pnpm-store/
.yarn/
jspm_packages/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env.*.local
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# ----- Build outputs -----
dist/
build/
out/
.next/
.turbo/
.vercel/
.nuxt/
.output/
coverage/
.nyc_output/

# ----- Environment variables & Secrets -----
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
*.pem
*.key
*.crt
studyverse-secrets.txt
secrets/

# ----- IDE / Editor -----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ----- OS junk -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Logs & Debug -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Cache -----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ----- Testing -----
.jest-cache/
playwright-report/
test-results/

# ----- Prisma (we'll use this later) -----
prisma/migrations/dev/
*.db
*.db-journal

# ----- Docker (later) -----
.docker/
docker-compose.override.yml

# ----- Local dev files -----
*.local
.local/
tmp/
temp/